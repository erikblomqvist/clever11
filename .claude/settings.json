{
	"permissions": {
		"allow": [
			"Bash(cd * && git status*)",
			"Bash(cd * && git diff*)",
			"Bash(cd * && git log*)",
			"Bash(cd * && cat *)",
			"Bash(cd * && grep *)",
			"Bash(cd * && find *)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-npm.sh",
						"timeout": 5,
						"statusMessage": "Checking package manager…"
					},
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/strip-redundant-git-c.sh",
						"timeout": 5,
						"statusMessage": "Checking git -C usage…"
					},
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-on-commit.sh",
						"if": "Bash(git commit *)",
						"timeout": 30,
						"statusMessage": "Linting before commit…"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prettier-on-edit.sh",
						"timeout": 10,
						"statusMessage": "Formatting…"
					},
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-on-edit.sh",
						"timeout": 15,
						"statusMessage": "Linting…"
					}
				]
			}
		]
	}
}
