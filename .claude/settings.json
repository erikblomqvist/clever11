{
    "permissions": {
        "allow": [
            "Bash(cd * && git status*)",
            "Bash(cd * && git diff*)",
            "Bash(cd * && git log*)",
            "Bash(cd * && cat *)",
            "Bash(cd * && grep *)",
            "Bash(cd * && find *)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-npm.sh",
                        "timeout": 5,
                        "statusMessage": "Checking package manager…"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-on-edit.sh",
                        "timeout": 30,
                        "statusMessage": "Linting…"
                    }
                ]
            },
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-on-edit.sh",
                        "timeout": 30,
                        "statusMessage": "Linting…"
                    }
                ]
            }
        ]
    }
}